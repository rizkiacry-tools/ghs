#!/bin/bash
set -euo pipefail

for cmd in gh jq fzf; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "ghs: requires $cmd" >&2; exit 1; }
done

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ghs"
CACHE_TTL=300
fzf_data=$(mktemp "${TMPDIR:-/tmp}/ghs_XXXXXX")
data_file=""
temp_dir=$(mktemp -d "${TMPDIR:-/tmp}/ghs_cleanup_XXXXXX")
trap 'rm -rf "$fzf_data" "$temp_dir"' EXIT

pipe_mode=0
json_mode=0
verbose=0
use_cache=1
limit=100
min_stars=1
since="2025-01-01"
sort_field="stars"
terms=()

i=0
while [ $i -lt $# ]; do
  a="${@:$((i+1)):1}"
  case "$a" in
    --pipe|--no-fzf|-p) pipe_mode=1 ;;

    --json|-j) json_mode=1 ;;
    --no-cache) use_cache=0 ;;
    --verbose|-v) verbose=1 ;;
    --help|-h) echo "Usage: ghs [options] <term1> [term2] ..."
              echo "Options:"
              echo "  -p, --pipe, --no-fzf   Print results to stdout (skip fzf)"
              echo "  --no-cache                    Skip cache, always fetch fresh"
              echo "  -j, --json                     Print raw JSON"
              echo "  -v, --verbose                  Show search status on stderr"
              echo "  -n, --limit N                  Max results (default 100)"
              echo "  -s, --stars N                  Min stars filter (default 1)"
              echo "  -d, --since DATE               Push date filter (default 2025-01-01)"
              echo "  -o, --sort FIELD               Sort: stars/updated/forks (default stars)"
              echo "  -h, --help                     This help"
              exit 0 ;;
    --limit|-n) limit="${@:$((i+2)):1}"; i=$((i+1)) ;;
    --stars|-s) min_stars="${@:$((i+2)):1}"; i=$((i+1)) ;;
    --since|-d) since="${@:$((i+2)):1}"; i=$((i+1)) ;;
    --sort|-o) sort_field="${@:$((i+2)):1}"; i=$((i+1)) ;;
    --*) echo "ghs: unknown flag $a" >&2; exit 1 ;;
    *) terms+=("$a") ;;
  esac
  i=$((i+1))
done

[ ${#terms[@]} -ge 1 ] || { echo "ghs: at least one search term required" >&2; exit 1; }
find "$CACHE_DIR" -type f -mmin +$((CACHE_TTL / 60)) -delete 2>/dev/null || true

SEARCH_LIMIT=500
t0=$(date +%s)
v() { [ "$verbose" -eq 1 ] && echo "ghs: $*" >&2; true; }

if [ "$use_cache" -eq 1 ]; then
  IFS=$'\n' sorted=($(sort <<<"${terms[*]}")); unset IFS
  cache_key=$(echo -n "${sorted[*]}" | md5 -q)
  cache_file="$CACHE_DIR/$cache_key.json"
  mkdir -p "$CACHE_DIR"
  now=$(date +%s)
  mod=$(stat -f %m "$cache_file" 2>/dev/null) || age=$((CACHE_TTL + 1))
  if [ -n "$mod" ]; then
    age=$((now - mod))
  else
    age=$((CACHE_TTL + 1))
  fi
fi

if [ "$use_cache" -eq 1 ] && [ "$age" -le "$CACHE_TTL" ]; then
  unique=$(jq length "$cache_file" 2>/dev/null || echo 0)
  v "cache hit, $unique repos (age $(($(date +%s)-$(stat -f %m "$cache_file" 2>/dev/null || echo $((now-1)))))s)"
  data_file="$cache_file"
else
  [ "$use_cache" -eq 1 ] && v "cache miss, searching..."
  combined='[]'
  for term in "${terms[@]}"; do
    result=$(gh search repos "$term" --sort "$sort_field" --limit "$SEARCH_LIMIT" \
      --json fullName,description,url,stargazersCount,pushedAt || echo '[]')
    count=$(echo "$result" | jq length)
    v "\"$term\" → $count repos"
    combined=$(jq -s 'add' <(echo "$combined") <(echo "$result"))
  done
  unique=$(echo "$combined" | jq 'unique_by(.url) | length')
  if [ "$use_cache" -eq 1 ]; then
    echo "$combined" | jq 'unique_by(.url)' > "$cache_file.tmp" && mv "$cache_file.tmp" "$cache_file"
    data_file="$cache_file"
  else
    data_file="$temp_dir/data.json"
    echo "$combined" | jq 'unique_by(.url)' > "$data_file"
  fi
  v "combined → $unique unique repos ($(($(date +%s)-t0))s)"
fi

t1=$(date +%s)

jq -r '
  .[] | [.fullName, (.description // ""), .stargazersCount, .pushedAt, .url, (.fullName + " " + (.description // "") | ascii_downcase)]
  | @tsv
' "$data_file" | awk -F'\t' -v terms="${terms[*]}" -v min_stars="$min_stars" -v since="$since" -v verbose="$verbose" '
BEGIN {
  n = split(tolower(terms), ts, " ")
  for (i = 1; i <= n; i++) ts[i] = ts[i]
}
{
  and_ok = 1
  txt = $6
  for (i = 1; i <= n; i++) {
    if (index(txt, ts[i]) == 0) { and_ok = 0; break }
  }
  star_ok = ($3 + 0 > min_stars + 0)
  date_ok = ($4 >= since)
  if (verbose) {
    printf "ghs:  %-42s AND %s stars %s date %s\n", $1, (and_ok ? "✓" : "✗"), (star_ok ? "✓" : "✗"), (date_ok ? "✓" : "✗") > "/dev/stderr"
  }
  if (and_ok && star_ok && date_ok) print $3 "|" $1 "|" $2 "|" $5
}' | sort -t'|' -k1 -rn | head -"$limit" | awk -F'|' '{n++; printf "  #%d  ★%s  %s  %s\t%s\n", n, $1, $2, $3, $4}' > "$fzf_data" &
pid=$!
wait "$pid" 2>/dev/null
fzfc=$(wc -l < "$fzf_data" 2>/dev/null | tr -d ' ') || fzfc=0
[ "$verbose" -eq 1 ] && echo "ghs: results: $fzfc repos passed ($(($(date +%s)-t1))s)" >&2

if [ "$json_mode" -eq 1 ]; then
  cat "$data_file"
elif [ "$pipe_mode" -eq 1 ]; then
  awk -F'\t' '{print $1}' "$fzf_data"
else
  while true; do
    selected=$(fzf --ansi --with-nth=1..4 < "$fzf_data")
    [ -n "$selected" ] || break
    url=$(echo "$selected" | awk -F'\t' '{print $2}')
    gh repo view --web "$url" 2>/dev/null || open "$url" 2>/dev/null || true
  done
fi
